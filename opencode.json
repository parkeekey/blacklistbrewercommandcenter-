{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "doom_loop": "allow"
  },
  "plugin": ["opencode-chrome-annotation@latest", "opencode-ponytail"],
  "provider": {
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama (local)",
      "options": {
        "baseURL": "http://localhost:11434/v1"
      },
      "models": {
        "qwen2.5-coder:7b": {
          "name": "Qwen 2.5 Coder 7B"
        }
      }
    },
    "headroom": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Headroom Proxy",
      "options": {
        "baseURL": "http://localhost:8787/v1"
      },
      "models": {
        "big-pickle": {
          "name": "Big Pickle (via Headroom)",
          "options": {
            "reasoningEffort": "none"
          }
        }
      }
    }
  }
}
